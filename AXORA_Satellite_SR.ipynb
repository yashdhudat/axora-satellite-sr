    "# ── Cell 6: Run on Sample or Uploaded Image ──────────────────────────────────\n",
    "import matplotlib.pyplot as plt\n",
    "import matplotlib.patches as mpatches\n",
    "\n",
    "# Create synthetic satellite image for demo\n",
    "def create_synthetic_satellite(size=96):\n",
    "    img = np.zeros((size, size, 3), dtype=np.uint8)\n",
    "    rng = np.random.RandomState(42)\n",
    "    for y in range(size):\n",
    "        for x in range(size):\n",
    "            n = rng.randint(-15, 15)\n",
    "            img[y, x] = [110+n, 100+n, 85+n]\n",
    "    img[size//2-2:size//2+2, :] = [160, 150, 135]\n",
    "    img[:, size//2-2:size//2+2] = [160, 150, 135]\n",
    "    for _ in range(10):\n",
    "        bx, by = rng.randint(5, size-15), rng.randint(5, size-15)\n",
    "        bw, bh = rng.randint(4, 12), rng.randint(4, 12)\n",
    "        c = rng.randint(80, 200)\n",
    "        img[by:by+bh, bx:bx+bw] = [c, c-10, c-20]\n",
    "    pil = Image.fromarray(img)\n",
    "    return pil.filter(ImageFilter.GaussianBlur(radius=0.8))\n",
    "\n",
    "# Uncomment to upload your own image:\n",
    "# from google.colab import files\n",
    "# uploaded = files.upload()\n",
    "# lr_image = Image.open(list(uploaded.keys())[0]).convert('RGB')\n",
    "\n",
    "lr_image = create_synthetic_satellite(96)\n",
    "print(f'Input image: {lr_image.width}×{lr_image.height} px')\n",
    "\n",
    "# Enhance\n",
    "print('\\n🚀 Running GAN Super-Resolution...')\n",
    "sr_image, bicubic_image, ms = enhance_satellite_image(lr_image, scale=4)\n",
    "\n",
    "# Metrics\n",
    "sr_np = np.array(sr_image)\n",
    "bic_np = np.array(bicubic_image)\n",
    "lr_up = np.array(lr_image.resize(sr_image.size, Image.BICUBIC))\n",
    "\n",
    "psnr_sr  = calculate_psnr(sr_np, lr_up)\n",
    "ssim_sr  = calculate_ssim(sr_np, lr_up)\n",
    "psnr_bic = calculate_psnr(bic_np, lr_up)\n",
    "ssim_bic = calculate_ssim(bic_np, lr_up)\n",
    "\n",
    "print(f'\\n{'='*50}')\n",
    "print(f'  AXORA RESULTS')\n",
    "print(f'{'='*50}')\n",
    "print(f'  Input     : {lr_image.width}×{lr_image.height} px')\n",
    "print(f'  Output    : {sr_image.width}×{sr_image.height} px (4×)')\n",
    "print(f'  Inf. Time : {ms:.1f} ms')\n",
    "print(f'{'─'*50}')\n",
    "print(f'              SR (OURS)    BICUBIC')\n",
    "print(f'  PSNR (dB) : {psnr_sr:>8.2f}   {psnr_bic:>8.2f}')\n",
    "print(f'  SSIM      : {ssim_sr:>8.4f}   {ssim_bic:>8.4f}')\n",
    "print(f'  PSNR gain : +{psnr_sr-psnr_bic:.2f} dB vs bicubic')\n",
    "print(f'{'='*50}')"
   ]
