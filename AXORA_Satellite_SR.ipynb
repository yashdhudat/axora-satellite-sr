    "# ── Cell 3: Download Pretrained Weights ─────────────────────────────────────\n",
    "import os\n",
    "\n",
    "os.makedirs('weights', exist_ok=True)\n",
    "\n",
    "# Real-ESRGAN weights (best for satellite imagery)\n",
    "weight_url = 'https://github.com/xinntao/Real-ESRGAN/releases/download/v0.1.0/RealESRGAN_x4plus.pth'\n",
    "weight_path = 'weights/RealESRGAN_x4plus.pth'\n",
    "\n",
    "if not os.path.exists(weight_path):\n",
    "    print('Downloading Real-ESRGAN x4 weights...')\n",
    "    !wget -q -O {weight_path} {weight_url}\n",
    "    print(f'✅ Downloaded: {os.path.getsize(weight_path)/1e6:.1f} MB')\n",
    "else:\n",
    "    print(f'✅ Weights already present: {weight_path}')"
   ]
