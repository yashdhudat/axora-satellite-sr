    "# ── Cell 4: AXORA SR Pipeline ────────────────────────────────────────────────\n",
    "import torch\n",
    "import numpy as np\n",
    "from PIL import Image, ImageFilter, ImageEnhance\n",
    "import time\n",
    "\n",
    "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
    "print(f'Device: {device}')\n",
    "if torch.cuda.is_available():\n",
    "    print(f'GPU: {torch.cuda.get_device_name(0)}')\n",
    "\n",
    "def calculate_psnr(img1, img2, max_val=255.0):\n",
    "    img1 = img1.astype(np.float64)\n",
    "    img2 = img2.astype(np.float64)\n",
    "    if img1.shape != img2.shape:\n",
    "        pil = Image.fromarray(img2.astype(np.uint8))\n",
    "        img2 = np.array(pil.resize((img1.shape[1], img1.shape[0]), Image.BICUBIC)).astype(np.float64)\n",
    "    mse = np.mean((img1 - img2) ** 2)\n",
    "    if mse < 1e-10:\n",
    "        return 100.0\n",
    "    return min(100.0, 20 * np.log10(max_val / np.sqrt(mse)))\n",
    "\n",
    "def calculate_ssim(img1, img2):\n",
    "    if img1.shape != img2.shape:\n",
    "        pil = Image.fromarray(img2.astype(np.uint8))\n",
    "        img2 = np.array(pil.resize((img1.shape[1], img1.shape[0]), Image.BICUBIC))\n",
    "    if img1.ndim == 3:\n",
    "        y1 = 0.299*img1[:,:,0] + 0.587*img1[:,:,1] + 0.114*img1[:,:,2]\n",
    "        y2 = 0.299*img2[:,:,0] + 0.587*img2[:,:,1] + 0.114*img2[:,:,2]\n",
    "    else:\n",
    "        y1, y2 = img1.astype(float), img2.astype(float)\n",
    "    C1, C2 = 6.5025, 58.5225\n",
    "    mu1, mu2 = y1.mean(), y2.mean()\n",
    "    s1, s2 = y1.std(), y2.std()\n",
    "    s12 = np.mean((y1-mu1)*(y2-mu2))\n",
    "    return float(((2*mu1*mu2+C1)*(2*s12+C2))/((mu1**2+mu2**2+C1)*(s1**2+s2**2+C2)))\n",
    "\n",
    "print('✅ Metrics functions loaded')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Cell 5: Load Real-ESRGAN Model ──────────────────────────────────────────\n",
    "try:\n",
    "    from realesrgan import RealESRGANer\n",
    "    from basicsr.archs.rrdbnet_arch import RRDBNet\n",
    "\n",
    "    model = RRDBNet(num_in_ch=3, num_out_ch=3, num_feat=64,\n",
    "                    num_block=23, num_grow_ch=32, scale=4)\n",
    "\n",
    "    upsampler = RealESRGANer(\n",
    "        scale=4,\n",
    "        model_path='weights/RealESRGAN_x4plus.pth',\n",
    "        model=model,\n",
    "        tile=256,\n",
    "        tile_pad=10,\n",
    "        pre_pad=0,\n",
    "        half=torch.cuda.is_available()\n",
    "    )\n",
    "    USE_ESRGAN = True\n",
    "    print('✅ Real-ESRGAN model loaded!')\n",
    "    print(f'   Half precision: {torch.cuda.is_available()}')\n",
    "except Exception as e:\n",
    "    print(f'⚠️  ESRGAN unavailable ({e}). Using enhanced PIL pipeline.')\n",
    "    USE_ESRGAN = False\n",
    "\n",
    "def enhance_satellite_image(lr_path_or_pil, scale=4):\n",
    "    \"\"\"Main enhancement function — uses ESRGAN or PIL fallback.\"\"\"\n",
    "    if isinstance(lr_path_or_pil, str):\n",
    "        lr_img = Image.open(lr_path_or_pil).convert('RGB')\n",
    "    else:\n",
    "        lr_img = lr_path_or_pil.convert('RGB')\n",
    "\n",
    "    start = time.time()\n",
    "\n",
    "    if USE_ESRGAN:\n",
    "        import cv2\n",
    "        lr_cv = cv2.cvtColor(np.array(lr_img), cv2.COLOR_RGB2BGR)\n",
    "        output, _ = upsampler.enhance(lr_cv, outscale=scale)\n",
    "        sr_img = Image.fromarray(cv2.cvtColor(output, cv2.COLOR_BGR2RGB))\n",
    "    else:\n",
    "        w, h = lr_img.width * scale, lr_img.height * scale\n",
    "        sr_img = lr_img.resize((w, h), Image.LANCZOS)\n",
    "        sr_img = sr_img.filter(ImageFilter.UnsharpMask(radius=1.5, percent=180, threshold=3))\n",
    "        sr_img = ImageEnhance.Sharpness(sr_img).enhance(1.8)\n",
    "        sr_img = ImageEnhance.Contrast(sr_img).enhance(1.12)\n",
    "\n",
    "    elapsed_ms = (time.time() - start) * 1000\n",
    "    bicubic = lr_img.resize((lr_img.width*scale, lr_img.height*scale), Image.BICUBIC)\n",
    "    return sr_img, bicubic, elapsed_ms\n",
    "\n",
    "print('✅ Enhancement pipeline ready!')"
   ]
  },
